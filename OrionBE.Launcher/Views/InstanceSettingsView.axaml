<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="using:OrionBE.Launcher.I18n"
             xmlns:vm="using:OrionBE.Launcher.ViewModels"
             x:Class="OrionBE.Launcher.Views.InstanceSettingsView"
             x:DataType="vm:InstanceSettingsViewModel">
    <Grid Margin="24" RowDefinitions="Auto,*,Auto">
        <TextBlock Grid.Row="0"
                   Text="{loc:LocalizerExtensions Key='launcher_instance_settings_title'}"
                   FontSize="26"
                   FontWeight="SemiBold"
                   Margin="0,0,0,16"/>

        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="16" MaxWidth="900">
                <Border Background="{DynamicResource OreSurfaceBrush}" CornerRadius="12" Padding="14">
                    <StackPanel Spacing="8">
                        <TextBlock Text="{loc:LocalizerExtensions Key='launcher_instance_settings_summary'}" FontWeight="SemiBold"/>
                        <TextBlock>
                            <Run Text="{loc:LocalizerExtensions Key='common_name_label'}"/>
                            <Run Text="{Binding DisplayName}"/>
                        </TextBlock>
                        <TextBlock>
                            <Run Text="{loc:LocalizerExtensions Key='common_version_label'}"/>
                            <Run Text="{Binding GameVersion}"/>
                        </TextBlock>
                        <TextBlock>
                            <Run Text="{loc:LocalizerExtensions Key='common_mods_enabled_label'}"/>
                            <Run Text="{Binding ModsEnabled}"/>
                        </TextBlock>
                        <TextBlock Text="{loc:LocalizerExtensions Key='launcher_instance_settings_instance_folder'}" Foreground="{DynamicResource OreMutedBrush}" Margin="0,8,0,0"/>
                        <DockPanel LastChildFill="True">
                            <Button DockPanel.Dock="Right"
                                    Content="{loc:LocalizerExtensions Key='common_open'}"
                                    MinWidth="88"
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Top"
                                    Command="{Binding OpenInExplorerCommand}"
                                    CommandParameter="{Binding InstanceRootPath}"/>
                            <TextBlock Text="{Binding InstanceRootPath}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                        </DockPanel>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource OreSurfaceBrush}"
                        CornerRadius="12"
                        Padding="14"
                        Opacity="{Binding UpgradeSectionOpacity}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{loc:LocalizerExtensions Key='launcher_instance_settings_bedrock_update'}" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding UpgradeHintText}"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource OreMutedBrush}"/>
                        <Button Content="{loc:LocalizerExtensions Key='launcher_instance_settings_update_channel_button'}"
                                Command="{Binding UpgradeBedrockCommand}"
                                MinWidth="260"
                                HorizontalAlignment="Left"
                                Background="{DynamicResource OreAccentBrush}"
                                Foreground="#FF0B120E"/>
                    </StackPanel>
                </Border>

                <Border IsVisible="{Binding ShowLinuxGdkSection}"
                        Background="{DynamicResource OreSurfaceBrush}"
                        CornerRadius="12"
                        Padding="14">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{loc:LocalizerExtensions Key='launcher_instance_settings_linux_gdk'}" FontWeight="SemiBold"/>
                        <TextBlock Text="{loc:LocalizerExtensions Key='launcher_instance_settings_linux_gdk_hint'}"
                                   Foreground="{DynamicResource OreMutedBrush}"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{loc:LocalizerExtensions Key='launcher_instance_settings_umu_run'}" Foreground="{DynamicResource OreMutedBrush}"/>
                        <DockPanel LastChildFill="True">
                            <Button DockPanel.Dock="Right" Content="{loc:LocalizerExtensions Key='common_open'}" MinWidth="88" Margin="12,0,0,0" VerticalAlignment="Top"
                                    Command="{Binding OpenInExplorerCommand}" CommandParameter="{Binding LinuxUmuRunPath}"/>
                            <TextBlock Text="{Binding LinuxUmuRunPath, TargetNullValue={loc:LocalizerExtensions Key='common_not_configured'}}" TextWrapping="Wrap"/>
                        </DockPanel>
                        <TextBlock Text="{loc:LocalizerExtensions Key='launcher_instance_settings_gdk_proton'}" Foreground="{DynamicResource OreMutedBrush}"/>
                        <DockPanel LastChildFill="True">
                            <Button DockPanel.Dock="Right" Content="{loc:LocalizerExtensions Key='common_open'}" MinWidth="88" Margin="12,0,0,0" VerticalAlignment="Top"
                                    Command="{Binding OpenInExplorerCommand}" CommandParameter="{Binding LinuxProtonPath}"/>
                            <TextBlock Text="{Binding LinuxProtonPath, TargetNullValue={loc:LocalizerExtensions Key='common_not_configured'}}" TextWrapping="Wrap"/>
                        </DockPanel>
                        <TextBlock Text="{loc:LocalizerExtensions Key='launcher_instance_settings_wineprefix'}" Foreground="{DynamicResource OreMutedBrush}"/>
                        <DockPanel LastChildFill="True">
                            <Button DockPanel.Dock="Right" Content="{loc:LocalizerExtensions Key='common_open'}" MinWidth="88" Margin="12,0,0,0" VerticalAlignment="Top"
                                    Command="{Binding OpenInExplorerCommand}" CommandParameter="{Binding LinuxWinePrefixPath}"/>
                            <TextBlock Text="{Binding LinuxWinePrefixPath, TargetNullValue={loc:LocalizerExtensions Key='common_not_configured'}}" TextWrapping="Wrap"/>
                        </DockPanel>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource OreSurfaceBrush}" CornerRadius="12" Padding="14">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{loc:LocalizerExtensions Key='launcher_instance_settings_bedrock_game'}" FontWeight="SemiBold"/>
                        <TextBlock Text="{loc:LocalizerExtensions Key='launcher_instance_settings_bedrock_game_hint'}"
                                   Foreground="{DynamicResource OreMutedBrush}"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{loc:LocalizerExtensions Key='launcher_instance_settings_bedrock_exe_label'}" Foreground="{DynamicResource OreMutedBrush}"/>
                        <DockPanel LastChildFill="True">
                            <Button DockPanel.Dock="Right" Content="{loc:LocalizerExtensions Key='common_open'}" MinWidth="88" Margin="12,0,0,0" VerticalAlignment="Top"
                                    Command="{Binding OpenInExplorerCommand}" CommandParameter="{Binding BedrockWindowsExecutablePath}"/>
                            <TextBlock Text="{Binding BedrockWindowsExecutablePath, TargetNullValue={loc:LocalizerExtensions Key='common_not_installed'}}" TextWrapping="Wrap"/>
                        </DockPanel>
                        <TextBlock>
                            <Run Text="{loc:LocalizerExtensions Key='common_package_uuid_label'}" Foreground="{DynamicResource OreMutedBrush}"/>
                            <Run Text="{Binding BedrockVersionUuid}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource OreSurfaceBrush}" CornerRadius="12" Padding="14" IsVisible="{Binding ModsEnabled}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{loc:LocalizerExtensions Key='launcher_instance_settings_levi_lamina'}" FontWeight="SemiBold"/>
                        <TextBlock Text="{loc:LocalizerExtensions Key='launcher_instance_settings_levi_hint'}"
                                   Foreground="{DynamicResource OreMutedBrush}"
                                   TextWrapping="Wrap"/>
                        <DockPanel LastChildFill="True">
                            <Button DockPanel.Dock="Right"
                                    Content="{loc:LocalizerExtensions Key='common_save'}"
                                    MinWidth="90"
                                    Margin="12,0,0,0"
                                    Command="{Binding SaveLeviLaminaVersionCommand}"/>
                            <TextBox Text="{Binding LeviLaminaVersion}"
                                     Watermark="{loc:LocalizerExtensions Key='launcher_instance_settings_levi_watermark'}"
                                     MinHeight="34"/>
                        </DockPanel>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource OreSurfaceBrush}" CornerRadius="12" Padding="14" IsVisible="{Binding ModsEnabled}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{loc:LocalizerExtensions Key='launcher_instance_settings_import_mods'}" FontWeight="SemiBold"/>
                        <TextBlock Text="{loc:LocalizerExtensions Key='launcher_instance_settings_import_hint'}"
                                   Foreground="{DynamicResource OreMutedBrush}"
                                   TextWrapping="Wrap"/>
                        <TextBox Text="{Binding ImportPath}" Watermark="{loc:LocalizerExtensions Key='launcher_instance_settings_import_path_watermark'}" MinHeight="34"/>
                        <TextBox Text="{Binding ImportDisplayName}" Watermark="{loc:LocalizerExtensions Key='launcher_instance_settings_import_name_watermark'}" MinHeight="34"/>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button Content="{loc:LocalizerExtensions Key='launcher_instance_settings_import_zip'}" Command="{Binding ImportZipCommand}" MinWidth="120"/>
                            <Button Content="{loc:LocalizerExtensions Key='launcher_instance_settings_import_dll'}" Command="{Binding ImportDllCommand}" MinWidth="120"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <StackPanel Spacing="8" IsVisible="{Binding ModsEnabled}">
                    <TextBlock Text="{loc:LocalizerExtensions Key='launcher_instance_settings_installed_mods'}" FontWeight="SemiBold"/>
                    <TextBlock Text="{loc:LocalizerExtensions Key='launcher_instance_settings_installed_mods_hint'}"
                               Foreground="{DynamicResource OreMutedBrush}"
                               TextWrapping="Wrap"/>

                    <ItemsControl ItemsSource="{Binding ModRows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:InstanceModRowViewModel">
                                <Border Margin="0,0,0,10"
                                        Padding="12"
                                        CornerRadius="10"
                                        Background="{DynamicResource OreSurfaceBrush}">
                                    <DockPanel LastChildFill="False">
                                        <ToggleSwitch DockPanel.Dock="Right"
                                                      IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                      OnContent="{loc:LocalizerExtensions Key='common_on'}"
                                                      OffContent="{loc:LocalizerExtensions Key='common_off'}"/>
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                            <TextBlock Foreground="{DynamicResource OreMutedBrush}">
                                                <Run Text="{loc:LocalizerExtensions Key='launcher_game_version_row_v_prefix'}"/>
                                                <Run Text="{Binding Version}"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding GlobalFolderName}" Foreground="{DynamicResource OreMutedBrush}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding CompatibilitySummary}"
                                                       Foreground="{DynamicResource OreMutedBrush}"/>
                                            <TextBlock Text="{loc:LocalizerExtensions Key='launcher_instance_settings_requires_levi'}"
                                                       IsVisible="{Binding RequiresLeviLamina}"
                                                       Foreground="{DynamicResource OreMutedBrush}"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto" Margin="0,16,0,0">
            <Button Grid.Column="0"
                    HorizontalAlignment="Left"
                    Content="{loc:LocalizerExtensions Key='launcher_instance_settings_back'}"
                    MinWidth="120"
                    Command="{Binding BackCommand}"/>
            <Button Grid.Column="2"
                    HorizontalAlignment="Right"
                    Content="{loc:LocalizerExtensions Key='launcher_instance_settings_delete_instance'}"
                    MinWidth="160"
                    Foreground="#FFFFE8E8"
                    Background="#88C42B2B"
                    Command="{Binding DeleteInstanceCommand}"/>
        </Grid>
    </Grid>
</UserControl>
