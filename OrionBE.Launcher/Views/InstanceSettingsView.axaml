<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OrionBE.Launcher.ViewModels"
             x:Class="OrionBE.Launcher.Views.InstanceSettingsView"
             x:DataType="vm:InstanceSettingsViewModel">
    <Grid Margin="24" RowDefinitions="Auto,*,Auto">
        <TextBlock Grid.Row="0"
                   Text="Instance settings"
                   FontSize="26"
                   FontWeight="SemiBold"
                   Margin="0,0,0,16"/>

        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="16" MaxWidth="900">
                <Border Background="{DynamicResource OreSurfaceBrush}" CornerRadius="12" Padding="14">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Summary" FontWeight="SemiBold"/>
                        <TextBlock>
                            <Run Text="Name:"/>
                            <Run Text="{Binding DisplayName}"/>
                        </TextBlock>
                        <TextBlock>
                            <Run Text="Version:"/>
                            <Run Text="{Binding GameVersion}"/>
                        </TextBlock>
                        <TextBlock>
                            <Run Text="Mods enabled:"/>
                            <Run Text="{Binding ModsEnabled}"/>
                        </TextBlock>
                        <TextBlock Text="Instance folder" Foreground="{DynamicResource OreMutedBrush}" Margin="0,8,0,0"/>
                        <DockPanel LastChildFill="True">
                            <Button DockPanel.Dock="Right"
                                    Content="Open"
                                    MinWidth="88"
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Top"
                                    Command="{Binding OpenInExplorerCommand}"
                                    CommandParameter="{Binding InstanceRootPath}"/>
                            <TextBlock Text="{Binding InstanceRootPath}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                        </DockPanel>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource OreSurfaceBrush}"
                        CornerRadius="12"
                        Padding="14"
                        Opacity="{Binding UpgradeSectionOpacity}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Bedrock update" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding UpgradeHintText}"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource OreMutedBrush}"/>
                        <Button Content="Update to latest in this channel"
                                Command="{Binding UpgradeBedrockCommand}"
                                MinWidth="260"
                                HorizontalAlignment="Left"
                                Background="{DynamicResource OreAccentBrush}"
                                Foreground="#FF0B120E"/>
                    </StackPanel>
                </Border>

                <Border IsVisible="{Binding ShowLinuxGdkSection}"
                        Background="{DynamicResource OreSurfaceBrush}"
                        CornerRadius="12"
                        Padding="14">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Linux GDK" FontWeight="SemiBold"/>
                        <TextBlock Text="Paths saved at install time (raonygamer/umu-launcher, raonygamer/gdk-proton)."
                                   Foreground="{DynamicResource OreMutedBrush}"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="umu-run" Foreground="{DynamicResource OreMutedBrush}"/>
                        <DockPanel LastChildFill="True">
                            <Button DockPanel.Dock="Right" Content="Open" MinWidth="88" Margin="12,0,0,0" VerticalAlignment="Top"
                                    Command="{Binding OpenInExplorerCommand}" CommandParameter="{Binding LinuxUmuRunPath}"/>
                            <TextBlock Text="{Binding LinuxUmuRunPath, TargetNullValue='(not configured)'}" TextWrapping="Wrap"/>
                        </DockPanel>
                        <TextBlock Text="GDK Proton (PROTONPATH directory)" Foreground="{DynamicResource OreMutedBrush}"/>
                        <DockPanel LastChildFill="True">
                            <Button DockPanel.Dock="Right" Content="Open" MinWidth="88" Margin="12,0,0,0" VerticalAlignment="Top"
                                    Command="{Binding OpenInExplorerCommand}" CommandParameter="{Binding LinuxProtonPath}"/>
                            <TextBlock Text="{Binding LinuxProtonPath, TargetNullValue='(not configured)'}" TextWrapping="Wrap"/>
                        </DockPanel>
                        <TextBlock Text="WINEPREFIX" Foreground="{DynamicResource OreMutedBrush}"/>
                        <DockPanel LastChildFill="True">
                            <Button DockPanel.Dock="Right" Content="Open" MinWidth="88" Margin="12,0,0,0" VerticalAlignment="Top"
                                    Command="{Binding OpenInExplorerCommand}" CommandParameter="{Binding LinuxWinePrefixPath}"/>
                            <TextBlock Text="{Binding LinuxWinePrefixPath, TargetNullValue='(not configured)'}" TextWrapping="Wrap"/>
                        </DockPanel>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource OreSurfaceBrush}" CornerRadius="12" Padding="14">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Bedrock game" FontWeight="SemiBold"/>
                        <TextBlock Text="Executable and package id (after installation)."
                                   Foreground="{DynamicResource OreMutedBrush}"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="Minecraft.Windows.exe" Foreground="{DynamicResource OreMutedBrush}"/>
                        <DockPanel LastChildFill="True">
                            <Button DockPanel.Dock="Right" Content="Open" MinWidth="88" Margin="12,0,0,0" VerticalAlignment="Top"
                                    Command="{Binding OpenInExplorerCommand}" CommandParameter="{Binding BedrockWindowsExecutablePath}"/>
                            <TextBlock Text="{Binding BedrockWindowsExecutablePath, TargetNullValue='(not installed)'}" TextWrapping="Wrap"/>
                        </DockPanel>
                        <TextBlock>
                            <Run Text="Package UUID: " Foreground="{DynamicResource OreMutedBrush}"/>
                            <Run Text="{Binding BedrockVersionUuid}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource OreSurfaceBrush}" CornerRadius="12" Padding="14" IsVisible="{Binding ModsEnabled}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="LeviLamina" FontWeight="SemiBold"/>
                        <TextBlock Text="Version installed in this instance (used to validate mod compatibility)."
                                   Foreground="{DynamicResource OreMutedBrush}"
                                   TextWrapping="Wrap"/>
                        <DockPanel LastChildFill="True">
                            <Button DockPanel.Dock="Right"
                                    Content="Save"
                                    MinWidth="90"
                                    Margin="12,0,0,0"
                                    Command="{Binding SaveLeviLaminaVersionCommand}"/>
                            <TextBox Text="{Binding LeviLaminaVersion}"
                                     Watermark="e.g. 1.1.0"
                                     MinHeight="34"/>
                        </DockPanel>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource OreSurfaceBrush}" CornerRadius="12" Padding="14" IsVisible="{Binding ModsEnabled}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Import local mods" FontWeight="SemiBold"/>
                        <TextBlock Text="Import a local .zip or .dll. Online mod browsing will be added later."
                                   Foreground="{DynamicResource OreMutedBrush}"
                                   TextWrapping="Wrap"/>
                        <TextBox Text="{Binding ImportPath}" Watermark="/path/to/mod.zip or .dll" MinHeight="34"/>
                        <TextBox Text="{Binding ImportDisplayName}" Watermark="Optional display name" MinHeight="34"/>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button Content="Import ZIP" Command="{Binding ImportZipCommand}" MinWidth="120"/>
                            <Button Content="Import DLL" Command="{Binding ImportDllCommand}" MinWidth="120"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <StackPanel Spacing="8" IsVisible="{Binding ModsEnabled}">
                    <TextBlock Text="Installed mods" FontWeight="SemiBold"/>
                    <TextBlock Text="Enable or disable; files remain on disk."
                               Foreground="{DynamicResource OreMutedBrush}"
                               TextWrapping="Wrap"/>

                    <ItemsControl ItemsSource="{Binding ModRows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:InstanceModRowViewModel">
                                <Border Margin="0,0,0,10"
                                        Padding="12"
                                        CornerRadius="10"
                                        Background="{DynamicResource OreSurfaceBrush}">
                                    <DockPanel LastChildFill="False">
                                        <ToggleSwitch DockPanel.Dock="Right"
                                                      IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                      OnContent="On"
                                                      OffContent="Off"/>
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Version, StringFormat=v{0}}" Foreground="{DynamicResource OreMutedBrush}"/>
                                            <TextBlock Text="{Binding GlobalFolderName}" Foreground="{DynamicResource OreMutedBrush}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding CompatibilitySummary}"
                                                       Foreground="{DynamicResource OreMutedBrush}"/>
                                            <TextBlock Text="Requires LeviLamina"
                                                       IsVisible="{Binding RequiresLeviLamina}"
                                                       Foreground="{DynamicResource OreMutedBrush}"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto" Margin="0,16,0,0">
            <Button Grid.Column="0"
                    HorizontalAlignment="Left"
                    Content="Back"
                    MinWidth="120"
                    Command="{Binding BackCommand}"/>
            <Button Grid.Column="2"
                    HorizontalAlignment="Right"
                    Content="Delete instance"
                    MinWidth="160"
                    Foreground="#FFFFE8E8"
                    Background="#88C42B2B"
                    Command="{Binding DeleteInstanceCommand}"/>
        </Grid>
    </Grid>
</UserControl>
