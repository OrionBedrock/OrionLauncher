<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:OrionBE.Launcher"
             xmlns:conv="using:OrionBE.Launcher.Infrastructure.Converters"
             x:Class="OrionBE.Launcher.App"
             RequestedThemeVariant="Dark">

    <Application.Resources>
        <conv:PathToBitmapConverter x:Key="PathBitmap"/>
    </Application.Resources>

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://OrionBE.Launcher/Assets/Themes/OreTheme.axaml"/>
    </Application.Styles>
</Application>
