<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:loc="using:OrionBE.Launcher.I18n"
             xmlns:vm="clr-namespace:OrionBe.ViewModel.Addons"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="OrionBe.View.Addons.AddonsView"
             x:DataType="vm:AddonsViewModel"
             Background="{DynamicResource Background}">
    <Border Padding="30, 140, 30, 30">
        <TextBlock Classes="h2"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Text="{loc:LocalizerExtensions Key='addons_placeholder'}"/>
    </Border>
</UserControl>
